        <!-- Badan mesin kasir -->
        <path
            android:fillColor="#38BDF8"
            android:pathData="M20,40 L52,40 L52,68 L20,68 Z" />

        <!-- Layar kasir -->
        <path
            android:fillColor="#0F172A"
            android:pathData="M22,42 L50,42 L50,52 L22,52 Z" />

        <!-- Teks di layar (simulasi) -->
        <path
