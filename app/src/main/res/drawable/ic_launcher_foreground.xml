            android:strokeWidth="1.5"
            android:strokeColor="#34D399" />

        <!-- Laci uang -->
        <path
            android:fillColor="#38BDF8"
            android:pathData="M24,54 L48,54 L48,66 L24,66 Z" />

        <!-- Garis laci -->
        <path
            android:fillColor="#0F172A"
            android:pathData="M24,58 L48,58"
            android:strokeWidth="1"
            android:strokeColor="#0F172A" />

        <!-- Receipt keluar -->
        <path
            android:fillColor="#F8FAFC"
            android:pathData="M30,30 L42,30 L42,42 L30,42 Z" />

        <!-- Garis receipt -->
        <path
            android:fillColor="#0F172A"
            android:pathData="M33,34 L39,34 M33,37 L38,37"
            android:strokeWidth="1"
            android:strokeColor="#0F172A" />

        <!-- Koin / pembayaran -->
        <circle
            android:fillColor="#FB923C"
            android:cx="54"
            android:cy="52"
            android:radius="6" />
        <circle
            android:fillColor="#34D399"
            android:cx="60"
            android:cy="58"
            android:radius="5" />
    </group>
</vector>
