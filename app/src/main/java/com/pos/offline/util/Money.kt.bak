package com.pos.offline.util

import java.text.DecimalFormat
import java.text.DecimalFormatSymbols
import java.util.Locale

/**
 * Util format mata uang Rupiah.
 *
 * Memakai [DecimalFormat] dengan grouping Indonesia (titik sebagai pemisah ribuan)
 * alih-alih NumberFormat.getCurrencyInstance — agar keluaran konsisten ("Rp 12.500")
 * di semua perangkat/locale dan tanpa digit desimal yang membingungkan.
 *
 * Uang sendiri disimpan sebagai Long (lihat Entity) → tidak ada pembulatan floating.
 */
private val rupiahFormatter: DecimalFormat = DecimalFormat(
    "#,###",
    DecimalFormatSymbols(Locale("id", "ID"))
).apply {
    maximumFractionDigits = 0
    minimumFractionDigits = 0
}

fun Long.toRupiah(): String = "Rp " + rupiahFormatter.format(this)

fun formatRupiah(amount: Long): String = amount.toRupiah()
