# Konfigurasi Gradle & JVM untuk performa build Android yang optimal
# gradle.properties

# 1. Alokasi Memori JVM (Ini adalah kunci utama agar GitHub Actions tidak error OOM)
org.gradle.jvmargs=-Xmx4g -Dfile.encoding=UTF-8 -XX:MaxMetaspaceSize=512m -XX:+UseParallelGC -XX:+HeapDumpOnOutOfMemoryError

# 2. Batasi jumlah pekerja (worker) paralel
org.gradle.workers.max=2

# 3. Pengaturan R8 dan Kotlin (Pertahankan false untuk menghemat memori sementara waktu)
kotlin.compiler.execution.strategy=in-process
kotlin.daemon.jvmargs=-Xmx512m

android.useAndroidX=true
android.nonTransitiveRClass=true
kotlin.code.style=official
org.gradle.parallel=true
org.gradle.caching=true
