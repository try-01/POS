name: Android CI 2

on:
  workflow_dispatch:
  # push:
  #   branches: [ main, master ]
  #   paths:
  #     - 'remote1/**'  # Diperbaiki dari remote1tv1

defaults:
  run:
    working-directory: ./remote1

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          distribution: 'temurin'
          java-version: '17'
          cache: 'gradle'
          # WAJIB DITAMBAHKAN agar cache bekerja untuk project di dalam folder 'remote1'
          cache-dependency-path: 'remote1/**/*.gradle*' 

      - name: Grant execute permission for gradlew
        run: chmod +x ./gradlew

      - name: Build and Test (Optimized)
        # Menambahkan prefix :app: agar build lebih terarah pada modul aplikasi utama
        run: |
          if [ "${{ github.ref }}" = "refs/heads/main" ] || [ "${{ github.ref }}" = "refs/heads/master" ]; then
            ./gradlew :app:testDebugUnitTest :app:assembleDebug :app:assembleRelease --no-daemon --parallel --build-cache --configure-on-demand
          else
            ./gradlew :app:testDebugUnitTest :app:assembleDebug --no-daemon --parallel --build-cache --configure-on-demand
          fi
        shell: bash

      - name: Upload debug APK artifact
        uses: actions/upload-artifact@v4
        with:
          name: debug-apk
          # Path diperbaiki dengan awalan remote1/
          path: remote1/app/build/outputs/apk/debug/app-debug.apk

      - name: Upload release APK artifact
        if: github.ref == 'refs/heads/main' || github.ref == 'refs/heads/master'
        uses: actions/upload-artifact@v4
        with:
          name: release-apk
          # Path diperbaiki dengan awalan remote1/
          path: remote1/app/build/outputs/apk/release/

      # --- STEP BARU: MENGUNGGAH LAPORAN PERFORMA COMPOSE ---
      - name: Upload Compose Performance Reports
        uses: actions/upload-artifact@v4
        with:
          name: compose-performance-report
          # Menggunakan awalan remote1/ karena aplikasi ada di sub-folder
          path: remote1/app/build/compose_metrics/
